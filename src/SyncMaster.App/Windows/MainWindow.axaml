<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SyncMaster.App.Windows.MainWindow"
        Title="SyncMaster"
        Icon="/Assets/icon.png"
        Width="440" Height="680"
        MinWidth="380" MinHeight="560"
        WindowDecorations="BorderOnly"
        Background="#0c0e16"
        CanResize="True"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">
  <!-- Native window decorations: the OS provides move / resize / minimize / close. The
       embedded WebView2 (or the loopback placeholder) fills the client area. The web UI
       hides its own cosmetic title bar when it detects the native shell. -->
  <Panel x:Name="HostPanel">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <TextBlock Text="SyncMaster"
                 Foreground="White"
                 FontSize="24"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <TextBlock x:Name="HostUrlText"
                 Text="Starting web panel…"
                 Foreground="#9FB0CC"
                 FontSize="13"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 MaxWidth="340" />
      <Button x:Name="OpenPanelButton"
              Content="Open web panel"
              HorizontalAlignment="Center" />
    </StackPanel>
  </Panel>
</Window>
