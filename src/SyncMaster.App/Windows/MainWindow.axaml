<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="SyncMaster.App.Windows.MainWindow"
        Title="SyncMaster"
        Width="420" Height="640"
        MinWidth="420" MinHeight="640"
        WindowDecorations="None"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
  <Border CornerRadius="16"
          Background="#101522"
          ClipToBounds="True">
    <Panel x:Name="HostPanel">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
        <TextBlock Text="SyncMaster"
                   Foreground="White"
                   FontSize="24"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <TextBlock x:Name="HostUrlText"
                   Text="Starting web panel…"
                   Foreground="#9FB0CC"
                   FontSize="13"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   MaxWidth="340" />
        <Button x:Name="OpenPanelButton"
                Content="Open web panel"
                HorizontalAlignment="Center" />
      </StackPanel>
    </Panel>
  </Border>
</Window>
