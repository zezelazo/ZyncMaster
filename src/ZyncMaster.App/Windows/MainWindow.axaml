<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZyncMaster.App.Windows.MainWindow"
        Title="Zync Master"
        Icon="/Assets/icon.png"
        Width="1100" Height="720"
        MinWidth="860" MinHeight="560"
        WindowDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        Background="#0c0e16"
        TransparencyLevelHint="None"
        CanResize="True"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">
  <!-- Frameless-but-resizable chrome, no top border. This is the Avalonia 12.x supported form for
       a custom-titlebar window on Windows: WindowDecorations="None" suppresses ALL native chrome
       (the thin top strip that WindowDecorations="BorderOnly" left behind is gone) and
       ExtendClientAreaToDecorationsHint="True" extends the client area over the decorations while
       the WM keeps a resizable frame — the WM still hit-tests the resize border ABOVE the WebView2
       child HWND, so 4-edge/corner resize and maximize/restore keep working with CanResize="True".

       NOTE on the API: Avalonia 12.0.3 REMOVED the old ExtendClientAreaChromeHints enum from Window
       (verified by reflecting Avalonia.Controls.dll: Window exposes only
       ExtendClientAreaToDecorationsHint, ExtendClientAreaTitleBarHeightHint, and the
       WindowDecorations enum {None, BorderOnly, Full}; the NoChrome value no longer exists). That is
       why the earlier ExtendClientAreaChromeHints="NoChrome" attribute failed with AVLN2000 — the
       enum is gone, not merely unresolvable as an attribute. The replacement is WindowDecorations="None".

       No "snow": transparency stays OFF + opaque Background, and the WebView2 host re-layouts on
       WindowState changes via the PropertyChanged handler in MainWindow.axaml.cs. The custom title
       bar (min/max/close + drag) lives in the web UI. -->
  <Panel x:Name="HostPanel">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <TextBlock Text="Zync Master"
                 Foreground="White"
                 FontSize="24"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <TextBlock x:Name="HostUrlText"
                 Text="Starting web panel…"
                 Foreground="#9FB0CC"
                 FontSize="13"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 MaxWidth="340" />
      <Button x:Name="OpenPanelButton"
              Content="Open web panel"
              HorizontalAlignment="Center" />
    </StackPanel>
  </Panel>
</Window>
