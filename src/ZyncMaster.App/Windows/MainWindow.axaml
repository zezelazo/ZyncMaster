<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="ZyncMaster.App.Windows.MainWindow"
        Title="Zync Master"
        Icon="/Assets/icon.png"
        Width="440" Height="680"
        MinWidth="380" MinHeight="560"
        WindowDecorations="BorderOnly"
        Background="#0c0e16"
        TransparencyLevelHint="None"
        CanResize="True"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen">
  <!-- Frameless-but-resizable chrome. ACTIVE = WindowDecorations="BorderOnly".
       This is the known-good behaviour the user verified: native resize on the 4 edges/
       corners (the WM hit-tests the border ABOVE the WebView2 child HWND, fixing the
       airspace fall-through) and working maximize/restore with no "snow" (transparency is
       OFF + opaque Background; the WebView2 host re-layouts on WindowState changes via the
       PropertyChanged handler in MainWindow.axaml.cs). The custom title bar (min/max/close +
       drag) lives in the web UI, so the look stays frameless apart from a thin top border.

       FOLLOW-UP (removing the thin top border): the extend-client-area approach
       (ExtendClientAreaToDecorationsHint + ExtendClientAreaChromeHints=NoChrome) does NOT
       compile as plain XAML attributes on Avalonia 12.0.3 (AVLN2000: the ChromeHints enum
       value doesn't resolve as an attribute here). Removing the top strip needs setting those
       in code-behind with the Avalonia.Platform enums, or a verified 12.x XAML form — left as
       a separate, properly-investigated change rather than risking the build. -->
  <Panel x:Name="HostPanel">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
      <TextBlock Text="Zync Master"
                 Foreground="White"
                 FontSize="24"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center" />
      <TextBlock x:Name="HostUrlText"
                 Text="Starting web panel…"
                 Foreground="#9FB0CC"
                 FontSize="13"
                 HorizontalAlignment="Center"
                 TextAlignment="Center"
                 TextWrapping="Wrap"
                 MaxWidth="340" />
      <Button x:Name="OpenPanelButton"
              Content="Open web panel"
              HorizontalAlignment="Center" />
    </StackPanel>
  </Panel>
</Window>
